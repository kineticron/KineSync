# DesktopBridge environment variables
# Copy to .env and fill in your values (never commit .env)

# --- ngrok relay mode ---
# Your ngrok static domain (e.g. your-subdomain.ngrok-free.app)
NGROK_URL=

# Bridge endpoint ID shown in the relay URL path (e.g. my-pc)
BRIDGE_RELAY_ID=

# Port the local relay server listens on (default: 8787)
BRIDGE_RELAY_PORT=8787

# ngrok binary path if not on PATH
NGROK_BIN=ngrok

# ngrok local API URL (default: http://127.0.0.1:4040/api/tunnels)
NGROK_API_URL=http://127.0.0.1:4040/api/tunnels

# --- bridge auth ---
# Handshake key — must match the key set in the mobile app Bridge Settings
BRIDGE_KEY=

# --- optional / advanced ---
# Override Musixmatch user token (normally set via UI)
MUSIXMATCH_USER_TOKEN=

# Override Spotify web token (normally set via UI)
SPOTIFY_WEB_TOKEN=

# Gemini API key for translation (normally set via UI)
GEMINI_API_KEY=

# OpenRouter API key (alternative to Gemini)
OPENROUTER_API_KEY=

# Enable verbose debug output for Spicetify lyrics source
SPICY_DEBUG=

# Enable CORS proxy for Spicetify lyrics source (true/false)
SPICY_LYRICS_USE_CORSPROXY=
